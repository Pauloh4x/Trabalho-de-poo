<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aula.LoginController"
            prefHeight="800.0" prefWidth="1000.0">
    <children>
        <VBox alignment="CENTER" spacing="20.0"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label alignment="CENTER" styleClass="titulo"
                       text="Login" />

                <Label styleClass="label-campo" text="Usuário" />
                <TextField fx:id="usuarioField"
                           alignment="CENTER"
                           maxWidth="350.0"
                           promptText="Digite seu usuário"
                           styleClass="campo" />

                <Label styleClass="label-campo" text="Senha" />
                <PasswordField fx:id="senhaField"
                               alignment="CENTER"
                               maxWidth="350.0"
                               promptText="Digite sua senha"
                               styleClass="campo" />

                <Button fx:id="loginButton"
                        alignment="CENTER"
                        mnemonicParsing="false"
                        styleClass="botao-login"
                        text="Entrar" />

                <Label alignment="CENTER" styleClass="label-link"
                       text="Não tem conta? Cadastre-se aqui" />
            </children>
        </VBox>
    </children>
</AnchorPane>